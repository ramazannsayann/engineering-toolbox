{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "engineering-toolbox",
  "compatibility_date": "2026-06-24",
  // Static assets-only deploy: no `main` (there is no Worker code). Cloudflare
  // serves the pre-rendered ./dist from the edge; dist/404.html handles misses.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
