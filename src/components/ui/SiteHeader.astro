---
import SearchPill from './SearchPill.astro';
import CategoryIcon from './CategoryIcon.astro';
---

<header class="sticky top-0 z-10 border-b border-hairline bg-bg/85 backdrop-blur">
  <div class="mx-auto flex h-14 max-w-5xl items-center justify-between gap-4 px-4">
    <a href="/" class="flex items-center gap-2 text-text">
      <span
        class="flex h-6 w-6 items-center justify-center rounded-[7px] text-accent"
        style="background: color-mix(in oklab, var(--color-accent) 14%, transparent)"
      >
        <CategoryIcon name="bolt" class="h-3.5 w-3.5" />
      </span>
      <span class="font-mono text-[13.5px] font-semibold tracking-tight">Engineering Toolbox</span>
    </a>
    <div class="hidden w-72 sm:block">
      <SearchPill />
    </div>
  </div>
</header>
