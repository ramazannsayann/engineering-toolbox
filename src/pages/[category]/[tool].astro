---
// Tool pages — ONE dynamic route over the registry (the scalable routing
// mechanism): getStaticPaths maps each WIRED calculator to /<categorySlug>/<toolSlug>.
//
// Island wiring: Astro builds a hydration script from a STATICALLY imported,
// directly-referenced component, so a `client:load` island cannot be pulled from
// a runtime map. Each tool's island is therefore a direct import gated by id.
// getStaticPaths only generates pages for ids in WIRED_ISLAND_IDS, so adding a
// calculator to the registry WITHOUT wiring its island here can never ship an
// empty tool page. Phase 1 adds a tool with: registry entry → island import →
// an id in WIRED_ISLAND_IDS → a render branch below.
import type { Calculator } from '../../calculators/types';
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getAllCalculators } from '../../calculators/registry';
import { getCategoryById } from '../../data/categories';
import OhmsLawCalculator from '../../components/calculators/OhmsLawCalculator';
import PowerTriangleCalculator from '../../components/calculators/PowerTriangleCalculator';
import PowerCalculator from '../../components/calculators/PowerCalculator';
import CurrentCalculator from '../../components/calculators/CurrentCalculator';
import CompensationCalculator from '../../components/calculators/CompensationCalculator';
import VoltageDropCalculator from '../../components/calculators/VoltageDropCalculator';
import CableSizingCalculator from '../../components/calculators/CableSizingCalculator';
import MotorCurrentCalculator from '../../components/calculators/MotorCurrentCalculator';
import TransformerSizingCalculator from '../../components/calculators/TransformerSizingCalculator';
import ShortCircuitCalculator from '../../components/calculators/ShortCircuitCalculator';
import ResistorColorCalculator from '../../components/calculators/ResistorColorCalculator';
import LedResistorCalculator from '../../components/calculators/LedResistorCalculator';
import TimerCalculator from '../../components/calculators/TimerCalculator';
import NumberBaseConverter from '../../components/calculators/NumberBaseConverter';
import DataSizeConverter from '../../components/calculators/DataSizeConverter';
import SubnetCalculator from '../../components/calculators/SubnetCalculator';
import ColorConverter from '../../components/calculators/ColorConverter';
import Base64Converter from '../../components/calculators/Base64Converter';
import UrlConverter from '../../components/calculators/UrlConverter';
import HashCalculator from '../../components/calculators/HashCalculator';
import JsonFormatter from '../../components/calculators/JsonFormatter';
import PasswordGenerator from '../../components/calculators/PasswordGenerator';
import UuidGenerator from '../../components/calculators/UuidGenerator';
import LengthConverter from '../../components/calculators/LengthConverter';

export function getStaticPaths() {
  // Defined inside getStaticPaths: Astro evaluates this export in its own scope,
  // so frontmatter-level consts are not available here.
  const WIRED_ISLAND_IDS = new Set<string>([
    'ohms-law',
    'guc-ucgeni',
    'guc-hesabi',
    'amper-hesabi',
    'kompanzasyon',
    'gerilim-dusumu',
    'kablo-kesiti',
    'motor-akimi',
    'trafo-boyutlandirma',
    'kisa-devre-akimi',
    'direnc-renk-kodu',
    'led-direnci',
    '555-timer',
    'sayi-tabani',
    'veri-boyutu',
    'ip-subnet',
    'renk-donusturucu',
    'base64',
    'url-encode',
    'hash',
    'json-formatla',
    'sifre-uretici',
    'uuid-uretici',
    'uzunluk-donusturucu',
  ]);
  return getAllCalculators()
    .filter((calculator) => WIRED_ISLAND_IDS.has(calculator.id))
    .map((calculator) => {
      const category = getCategoryById(calculator.categoryId);
      if (!category) {
        // categoryId is an invariant — fail the build rather than coin an
        // orphan URL on a raw English segment with no category page.
        throw new Error(
          `Calculator "${calculator.id}" has unknown categoryId "${calculator.categoryId}". ` +
            'Add the category to src/data/categories.ts.',
        );
      }
      return {
        params: { category: category.slug, tool: calculator.slug },
        props: { calculator },
      };
    });
}

interface Props {
  calculator: Calculator;
}
const { calculator } = Astro.props;
---

<ToolLayout calculator={calculator}>
  {calculator.id === 'ohms-law' && <OhmsLawCalculator client:load />}
  {calculator.id === 'guc-ucgeni' && <PowerTriangleCalculator client:load />}
  {calculator.id === 'guc-hesabi' && <PowerCalculator client:load />}
  {calculator.id === 'amper-hesabi' && <CurrentCalculator client:load />}
  {calculator.id === 'kompanzasyon' && <CompensationCalculator client:load />}
  {calculator.id === 'gerilim-dusumu' && <VoltageDropCalculator client:load />}
  {calculator.id === 'kablo-kesiti' && <CableSizingCalculator client:load />}
  {calculator.id === 'motor-akimi' && <MotorCurrentCalculator client:load />}
  {calculator.id === 'trafo-boyutlandirma' && <TransformerSizingCalculator client:load />}
  {calculator.id === 'kisa-devre-akimi' && <ShortCircuitCalculator client:load />}
  {calculator.id === 'direnc-renk-kodu' && <ResistorColorCalculator client:load />}
  {calculator.id === 'led-direnci' && <LedResistorCalculator client:load />}
  {calculator.id === '555-timer' && <TimerCalculator client:load />}
  {calculator.id === 'sayi-tabani' && <NumberBaseConverter client:load />}
  {calculator.id === 'veri-boyutu' && <DataSizeConverter client:load />}
  {calculator.id === 'ip-subnet' && <SubnetCalculator client:load />}
  {calculator.id === 'renk-donusturucu' && <ColorConverter client:load />}
  {calculator.id === 'base64' && <Base64Converter client:load />}
  {calculator.id === 'url-encode' && <UrlConverter client:load />}
  {calculator.id === 'hash' && <HashCalculator client:load />}
  {calculator.id === 'json-formatla' && <JsonFormatter client:load />}
  {calculator.id === 'sifre-uretici' && <PasswordGenerator client:load />}
  {calculator.id === 'uuid-uretici' && <UuidGenerator client:load />}
  {calculator.id === 'uzunluk-donusturucu' && <LengthConverter client:load />}
</ToolLayout>
