---
// Inline category icons (no icon library). One tidy id -> SVG-paths map; the
// icon id comes from src/data/categories.ts.
interface Props {
  name: string;
  class?: string;
}
const { name, class: className = 'h-5 w-5' } = Astro.props;

const ICONS: Record<string, string> = {
  bolt: '<path d="M13 2 4.5 13.5H11l-1 8.5L19.5 10H13l1-8z" />',
  airflow:
    '<path d="M3 8h10a3 3 0 1 0-3-3" /><path d="M3 12h14a3 3 0 1 1-3 3" /><path d="M3 16h7a2.5 2.5 0 1 1-2.5 2.5" />',
  heat: '<path d="M8 21c0-2.5 2-2.5 2-5s-2-2.5-2-5 2-2.5 2-5" /><path d="M14 21c0-2.5 2-2.5 2-5s-2-2.5-2-5 2-2.5 2-5" />',
  convert: '<path d="M4 8h13l-3.5-3.5" /><path d="M20 16H7l3.5 3.5" />',
  chip: '<rect x="6.5" y="6.5" width="11" height="11" rx="1.5" /><path d="M9.5 3v3.5M14.5 3v3.5M9.5 17.5V21M14.5 17.5V21M3 9.5h3.5M3 14.5h3.5M17.5 9.5H21M17.5 14.5H21" />',
};
const inner = ICONS[name] ?? ICONS.bolt;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={inner}
></svg>
